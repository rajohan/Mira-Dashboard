{
    "name": "mira-dashboard",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "packageManager": "bun@1.3.14",
    "browserslist": [
        "Chrome >= 140",
        "Firefox >= 133",
        "Safari >= 18.4"
    ],
    "scripts": {
        "dev": "bun --watch scripts/developmentFrontend.ts",
        "build": "tsc -b && bun scripts/buildFrontend.ts",
        "lint": "eslint . --max-warnings=0",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"backend/**/*.{ts,js}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"backend/**/*.{ts,js}\"",
        "preview": "bun scripts/developmentFrontend.ts",
        "test": "bun test",
        "test:coverage": "bun scripts/runCoverage.ts 85 src/"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/react": "^0.5.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@headlessui/react": "^2.2.10",
        "@microlink/react-json-view": "^1.31.22",
        "@tailwindcss/typography": "^0.5.20",
        "@tanstack/query-core": "5.101.2",
        "@tanstack/query-db-collection": "^1.0.46",
        "@tanstack/react-db": "^0.1.92",
        "@tanstack/react-form": "^1.33.0",
        "@tanstack/react-query": "^5.101.2",
        "@tanstack/react-router": "^1.170.17",
        "@tanstack/react-store": "^0.11.0",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.14.5",
        "clsx": "^2.1.1",
        "date-fns": "^4.4.0",
        "json5": "^2.2.3",
        "lucide-react": "^1.23.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-error-boundary": "^6.1.2",
        "react-markdown": "^10.1.0",
        "react-syntax-highlighter": "^16.1.1",
        "rehype-raw": "^7.0.0",
        "rehype-sanitize": "^6.0.0",
        "remark-frontmatter": "^5.0.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@eslint/js": "^10.0.1",
        "@happy-dom/global-registrator": "^20.10.6",
        "@tanstack/react-devtools": "^0.10.8",
        "@tanstack/react-form-devtools": "^0.2.29",
        "@tanstack/react-query-devtools": "^5.101.2",
        "@tanstack/react-router-devtools": "1.167.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/babel__core": "^7.20.5",
        "@types/bun": "^1.3.14",
        "@types/node": "26.1.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "babel-plugin-react-compiler": "^1.0.0",
        "bun-plugin-tailwind": "^0.1.2",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-tailwindcss": "^4.0.6",
        "eslint-plugin-unicorn": "^71.0.0",
        "globals": "^17.7.0",
        "happy-dom": "^20.10.6",
        "prettier": "^3.9.4",
        "tailwindcss": "^4.3.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1"
    }
}
