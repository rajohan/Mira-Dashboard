{
    "name": "mira-dashboard-backend",
    "version": "1.0.0",
    "description": "Gateway Mirror backend for Mira Dashboard",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "doppler run --config prd --project rajohan -- node dist/server.js",
        "dev": "doppler run --config prd --project rajohan -- tsx watch src/server.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write '**/*.{ts,js}'",
        "format:check": "prettier --check '**/*.{ts,js}'",
        "test": "node --test-concurrency=1 --import tsx --test \"src/**/*.test.ts\""
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "json5": "^2.2.3",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.2",
        "@types/ws": "^8.18.1",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "prettier": "^3.8.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2"
    }
}
