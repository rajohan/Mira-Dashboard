{
    "name": "mira-dashboard-backend",
    "version": "1.0.0",
    "description": "Gateway Mirror backend for Mira Dashboard",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "tsx watch src/server.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write '**/*.{ts,js}'",
        "format:check": "prettier --check '**/*.{ts,js}'"
    },
    "dependencies": {
        "dotenv": "^17.3.1",
        "express": "^4.22.1",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.3.3",
        "@types/ws": "^8.18.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-unicorn": "^63.0.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.34.0"
    }
}
