{
    "name": "mira-dashboard-backend",
    "version": "1.0.0",
    "description": "Gateway Mirror backend for Mira Dashboard",
    "main": "dist/serverStart.js",
    "type": "module",
    "packageManager": "bun@1.3.14",
    "scripts": {
        "build": "tsc --noEmit && bun scripts/build.ts",
        "start": "NODE_ENV=production doppler run --config prd --project rajohan -- bun dist/serverStart.js",
        "dev": "MIRA_DASHBOARD_DISABLE_SCHEDULER=1 doppler run --config prd --project rajohan -- bun --watch src/serverStart.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write '**/*.{ts,js}'",
        "format:check": "prettier --check '**/*.{ts,js}'",
        "test": "bun test",
        "test:coverage": "bun ../scripts/runCoverage.ts 85 src/"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "^1.3.14",
        "@types/node": "26.1.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-unicorn": "^71.0.0",
        "prettier": "^3.9.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1"
    }
}
